# TalkDude Frontend - Environment Variables Template

# Backend API URL (e.g., https://your-backend.onrender.com/api)
VITE_BACKEND_URL=your_backend_url_here

# Get-Stream API Key
VITE_STREAM_API_KEY=your_stream_api_key_here

# Frontend Client URL (e.g., https://your-app.vercel.app/)
VITE_CLIENT_URL=your_frontend_url_here
VITE_FRONTEND_URL=your_frontend_url_here

# Clerk Publishable Key (Clerk Dashboard -> API Keys)
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
